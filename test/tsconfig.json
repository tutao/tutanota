{
	"extends": "../tsconfig_common.json",
	"compilerOptions": {
		"declaration": false,
		"noEmit": false,
		"noImplicitAny": false,
		"noImplicitThis": false,
		"strictPropertyInitialization": false,
		"strictBindCallApply": false,
		"outDir": "build",
		"resolveJsonModule": true,
		"sourceMap": false,
		"paths": {
			/**
			 * Have to redefine all paths again defined in: `../tsconfig_common.json`
			 * See: https://github.com/microsoft/TypeScript/issues/57486
			 */
			"@tutao/utils": ["../src/utils"],
			"@tutao/crypto": ["../src/crypto"],
			"@tutao/crypto/error": ["../src/platform-kits/cryptoerror"],
			"@tutao/usagetests": ["../src/usagetests"],
			"@tutao/mimimi": ["../src/mimimi"],
			"@tutao/mimimi/types": ["../src/mimimi/napi-out/binding.d.ts"],
			"@tutao/otest": ["./otest"],
			"@tutao/app-env": ["../src/app-env"],
			"@tutao/rest-client": ["../src/rest-client"],
			"@tutao/rest-client/error": ["../src/rest-client/error.ts"],
			"@tutao/rest-client/types": ["../src/rest-client/types.d.ts"],
			"@tutao/meta": ["../src/meta"],
			"@tutao/network": ["../src/network"],
			"@tutao/network/types": ["../src/network/types.d.ts"],
			"@tutao/typerefs": ["../src/typerefs"],
			"@tutao/entities/accounting": ["../src/entities/accounting"],
			"@tutao/entities/base": ["../src/entities/base"],
			"@tutao/entities/drive": ["../src/entities/drive"],
			"@tutao/entities/monitor": ["../src/entities/monitor"],
			"@tutao/entities/storage": ["../src/entities/storage"],
			"@tutao/entities/sys": ["../src/entities/sys"],
			"@tutao/entities/tutanota": ["../src/entities/tutanota"],
			"@tutao/entities/usage": ["../src/entities/usage"],
			"@tutao/instance-pipeline": ["../src/instance-pipeline"],
			"@tutao/licc": ["../src/licc"],
			"@tutao/licc-parser": ["../src/licc/Parser"],
			"@tutao/crypto/rsa": ["../src/platform-kits/cryptoencryption/Rsa"],
			"@tutao/crypto/random": ["../src/platform-kits/cryptorandom/SecureRandom"],
			"@tutao/crypto/symmetric-cipher-utils": [
				"../src/platform-kits/cryptoencryption/symmetric/SymmetricCipherUtils"
			],
			"@tutao/crypto/symmetric-cipher-facade": [
				"../src/platform-kits/cryptoencryption/symmetric/SymmetricCipherFacade"
			],
			"@tutao/crypto/symmetric-key-deriver": [
				"../src/platform-kits/cryptoencryption/symmetric/SymmetricKeyDeriver"
			],
			"@tutao/crypto/symmetric-cipher-version": [
				"../src/platform-kits/cryptoencryption/symmetric/SymmetricCipherVersion"
			],
			"@tutao/crypto/aes-cbc-facade": ["../src/platform-kits/cryptoencryption/symmetric/AesCbcFacade"],
			"@tutao/crypto/sha256": ["../src/platform-kits/cryptohashes/Sha256"],
			"@tutao/crypto/blake3": ["../src/platform-kits/cryptohashes/Blake3"],
			"@tutao/crypto/sjcl": ["../src/platform-kits/cryptointernal/sjcl.js"],
			"@tutao/crypto/jsbn": ["../src/platform-kits/cryptointernal/crypto-jsbn-2012-08-09_1.js"]
		}
	},
	"include": ["../src/*d.ts", "../libs/*d.ts", "../types/*d.ts", "tests/**/*.ts", "types/*.d.ts"],
	"exclude": ["build"],
	"types": ["node_modules/@types/node"],
	"references": [
		{
			"path": "tsconfig.otest.json"
		},
		{
			"path": "../src/tsconfig.combined-apps.json"
		}
	]
}
