{
	"extends": "../tsconfig_common.json",
	"compilerOptions": {
		"declaration": false,
		"noEmit": false,
		"noImplicitAny": false,
		"noImplicitThis": false,
		"strictPropertyInitialization": false,
		"strictBindCallApply": false,
		"outDir": "build",
		"resolveJsonModule": true,
		"sourceMap": false,
		"paths": {
			/**
			 * Have to redefine all paths again defined in: `../tsconfig_common.json`
			 * See: https://github.com/microsoft/TypeScript/issues/57486
			 */
			"@tutao/utils": ["../src/utils"],
			"@tutao/crypto": ["../src/crypto"],
			"@tutao/crypto/error": ["../src/crypto/error"],
			"@tutao/error": ["../src/error"],
			"@tutao/wasm-loader": ["../src/wasm-loader"],
			"@tutao/usagetests": ["../src/usagetests"],
			"@tutao/mimimi": ["../src/mimimi"],
			"@tutao/otest": ["./otest"],
			"@tutao/licc": ["../src/licc"],
			"@tutao/licc-parser": ["../src/licc/Parser"],

			"@tutao/crypto/rsa": ["../src/crypto/encryption/Rsa"],
			"@tutao/crypto/random": ["../src/crypto/random/SecureRandom"],
			"@tutao/crypto/symmetric-cipher-utils": ["../src/crypto/encryption/symmetric/SymmetricCipherUtils"],
			"@tutao/crypto/symmetric-cipher-facade": ["../src/crypto/encryption/symmetric/SymmetricCipherFacade"],
			"@tutao/crypto/symmetric-key-deriver": ["../src/crypto/encryption/symmetric/SymmetricKeyDeriver"],
			"@tutao/crypto/symmetric-cipher-version": ["../src/crypto/encryption/symmetric/SymmetricCipherVersion"],
			"@tutao/crypto/aes-cbc-facade": ["../src/crypto/encryption/symmetric/AesCbcFacade"],
			"@tutao/crypto/sha256": ["../src/crypto/hashes/Sha256"],
			"@tutao/crypto/blake3": ["../src/crypto/hashes/Blake3"],
			"@tutao/crypto/sjcl": ["../src/crypto/internal/sjcl.js"],
			"@tutao/crypto/jsbn": ["../src/crypto/internal/crypto-jsbn-2012-08-09_1.js"]
		}
	},
	"include": ["../src/*d.ts", "../libs/*d.ts", "../types/*d.ts", "tests/**/*.ts", "types/*.d.ts"],
	"exclude": ["build"],
	"types": ["node_modules/@types/node"],
	"references": [
		{
			"path": "tsconfig.otest.json"
		},
		{
			"path": "../src/tsconfig.error.json"
		},
		{
			"path": "../src/tsconfig.crypto.json"
		},
		{
			"path": "../src/tsconfig.utils.json"
		},
		{
			"path": "../src/tsconfig.mimimi.json"
		},
		{
			"path": "../src/tsconfig.wasm.json"
		},
		{
			"path": "../src/tsconfig.usagetests.json"
		}
	]
}
