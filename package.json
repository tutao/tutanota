{
	"name": "tutanota",
	"version": "345.260423.0",
	"license": "GPL-3.0",
	"repository": {
		"type": "git",
		"url": "https://github.com/tutao/tutanota.git"
	},
	"type": "module",
	"scripts": {
		"start": "./start-desktop.sh",
		"build-packages": "echo '>>>> You no longer need to execute this <<<<<'",
		"test-ci": "cd test && node test --ci",
		"test": "cd test && node --enable-source-maps test",
		"mail:types": "tsc --build --incremental true tsconfig.json",
		"calendar:types": "tsc --build --incremental true tsconfig-calendar-app.json",
		"test:types": "tsc --build --incremental true test/tsconfig.json",
		"prebuild": "node buildSrc/prebuild.js",
		"preinstall": "node buildSrc/preinstall.js",
		"postinstall": "node buildSrc/postinstall.js",
		"bump-version": "node buildSrc/bump-version.js",
		"generate-ipc": "tsc --build src/tsconfig.licc.json && node src/licc/dist/cli.js ipc-schema && npm run style:fix",
		"style:check": "prettier -c \"**/*.(ts|js|json|json5)\" --cache --cache-location cache/prettier",
		"style:fix": "prettier -w \"**/*.(ts|js|json|json5)\"",
		"lint:check": "eslint . --cache --cache-location cache/eslint",
		"lint:fix": "eslint --fix .",
		"check": "npm run style:check && npm run lint:check",
		"fix": "npm run style:fix && npm run lint:fix",
		"trace-imports": "node --import ./buildSrc/review/import-hooks.js",
		"review-import-trace": "node ./buildSrc/review/review.js import-trace.json",
		"ios:generate-project": "cd app-ios && xcodegen --spec mail-project.yml && xcodegen --spec calendar-project.yml"
	},
	"dependencies": {
		"@indutny/simple-windows-notifications": "git+https://github.com/tutao/simple-windows-notifications.git#58600c1639ff47a1bae5e195ac8b52e87b17796e",
		"@fingerprintjs/botd": "1.9.1",
		"@material/material-color-utilities": "git+https://github.com/tutao/material-color-utilities#064dcc2768cb0c8106c150a819eedb6233bb1d0a",
		"@signalapp/sqlcipher": "git+https://github.com/tutao/node-sqlcipher#8d7eaa36321d7147faa3583231635855d8a991e7",
		"@tensorflow/tfjs-core": "4.22.0",
		"@tensorflow/tfjs-layers": "4.22.0",
		"@tensorflow/tfjs-backend-webgl": "4.22.0",
		"@tensorflow/tfjs-backend-cpu": "4.22.0",
		"@tutao/oxmsg": "0.0.9-beta.0",
		"@types/better-sqlite3": "7.4.2",
		"@types/luxon": "3.6.2",
		"@types/mithril": "2.0.11",
		"@types/qrcode-svg": "1.1.4",
		"cborg": "4.2.2",
		"dompurify": "3.4.0",
		"electron": "41.2.0",
		"electron-updater": "6.7.3",
		"jsqr": "1.4.0",
		"jszip": "3.10.1",
		"linkify-html": "4.3.2",
		"linkifyjs": "4.3.2",
		"luxon": "3.6.1",
		"mithril": "2.2.2",
		"pako": "2.1.0",
		"qrcode-svg": "1.1.0",
		"squire-rte": "2.2.7",
		"undici": "7.24.4"
	},
	"optionalDependencies": {
		"dmg-license": "^1.0.11"
	},
	"devDependencies": {
		"@electron/notarize": "3.0.1",
		"@eslint/js": "9.29.0",
		"@octokit/auth-token": "6.0.0",
		"@octokit/rest": "22.0.0",
		"@rollup/plugin-alias": "5.1.1",
		"@rollup/plugin-commonjs": "26.0.1",
		"@rollup/plugin-json": "6.1.0",
		"@rollup/plugin-node-resolve": "15.3.1",
		"@rollup/plugin-replace": "^6.0.2",
		"@rollup/plugin-terser": "0.4.4",
		"@rollup/plugin-typescript": "12.1.2",
		"@types/express": "5.0.3",
		"@types/node": "22.16.0",
		"@types/pako": "^2.0.3",
		"body-parser": "2.2.0",
		"commander": "14.0.0",
		"json5": "^2.2.1",
		"electron-builder": "26.7.0",
		"eslint": "9.29.0",
		"eslint-plugin-unicorn": "59.0.1",
		"express": "5.1.0",
		"fs-extra": "11.3.0",
		"globals": "16.2.0",
		"js-yaml": "4.1.0",
		"jsdom": "26.1.0",
		"node-gyp": "11.2.0",
		"octokit": "5.0.3",
		"prettier": "3.5.3",
		"rolldown": "1.0.0-rc.5",
		"rollup": "4.60.0",
		"rollup-plugin-visualizer": "6.0.3",
		"testdouble": "3.20.2",
		"typescript": "5.8.3",
		"typescript-eslint": "8.34.0",
		"xhr2": "0.2.1",
		"zx": "8.5.5",
		"wasm-pack": "git+https://github.com/tutao/wasm-pack.git#b1e0e982fee26803ba6b8a8c29197d2a8cdd93f3"
	},
	"workspaces": [
		"./src/licc"
	],
	"engines": {
		"npm": ">=10.0.0",
		"node": ">=22.16.0"
	}
}
