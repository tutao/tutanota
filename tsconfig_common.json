{
	"compilerOptions": {
		"lib": ["es2023", "webworker", "dom"],
		"allowJs": true,
		"checkJs": false,
		"target": "es2022",
		"module": "es2022",
		"moduleResolution": "bundler",
		"skipLibCheck": true,
		"declaration": true,
		"noEmitOnError": true,
		"noErrorTruncation": true,
		"allowSyntheticDefaultImports": true,
		"noImplicitAny": true,
		"noImplicitThis": true,
		"noUnusedLocals": false,
		"noUnusedParameters": false,
		"esModuleInterop": true,
		"strict": false,
		"alwaysStrict": true,
		"strictBindCallApply": true,
		"strictFunctionTypes": false,
		"strictPropertyInitialization": true,
		"noStrictGenericChecks": false,
		"strictNullChecks": true,
		"useUnknownInCatchVariables": false,
		"types": ["node"],
		"incremental": true,
		"paths": {
			"tutanota-3:/*": ["../client/*"],
			"@tutao/utils": ["./src/utils"],
			"@tutao/crypto-primitives": ["./src/crypto-primitives/crypto_primitives"],
			"@tutao/crypto": ["./src/crypto"],
			"@tutao/crypto/error": ["./src/crypto/error"],
			"@tutao/wasm-loader": ["./src/wasm-loader"],
			"@tutao/usagetests": ["./src/usagetests"],
			"@tutao/mimimi": ["./src/mimimi"],
			"@tutao/mimimi/types": ["./src/mimimi/napi-out/binding.d.ts"],
			"@tutao/otest": ["./test/otest"],
			"@tutao/rest-client": ["./src/rest-client"],
			"@tutao/rest-client/types": ["./src/rest-client/types.d.ts"],
			"@tutao/rest-client/error": ["./src/rest-client/error.ts"],
			"@tutao/app-env": ["./src/app-env"],
			"@tutao/typerefs": ["./src/typerefs"],
			"@tutao/instance-pipeline": ["./src/instance-pipeline"],
			"@tutao/native-bridge": ["./src/native-bridge"]
		}
	}
}
