{
	"extends": "../tsconfig_common.json",
	"include": [
		"../types/*.d.ts",
		"./crypto/encryption",
		"./crypto/hashes",
		"./crypto/misc",
		"./crypto/random",
		"./crypto/make.ts"
	],
	"exclude": ["crypto/dist"],
	"files": [
		"crypto/index.ts",
		"crypto/error.ts",
		"crypto/internal/bCrypt.js",
		"crypto/internal/crypto-jsbn-2012-08-09_1.js",
		"crypto/internal/sjcl.js",
		"crypto/internal/noble-curves-1.3.0.js",
		"crypto/internal/noble-hashes-2.0.1.js"
	],
	"compilerOptions": {
		"rootDir": "crypto",
		"outDir": "crypto/dist",
		"tsBuildInfoFile": "crypto/dist/tsbuildinfo",
		"composite": true
	},
	"references": [
		{
			"path": "tsconfig.utils.json"
		},
		{
			"path": "tsconfig.error.json"
		}
	]
}
